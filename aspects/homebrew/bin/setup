#!/usr/bin/env bash
# Author: Andy Gorman
#
# Installs everything listed in aspects/homebrew/Brewfile.

set -e

if ! command -v brew &> /dev/null; then
	echo "Homebrew is not installed. Run bin/bootstrap first." >&2
	exit 1
fi

ASPECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "Running brew bundle..."
brew bundle --file="${ASPECT_DIR}/Brewfile"
echo "Brew bundle complete."
