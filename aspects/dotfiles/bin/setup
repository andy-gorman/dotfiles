#!/usr/bin/env bash
# Author: Andy Gorman

set -e

pushd "$(dirname "${BASH_SOURCE[0]}")/.." &> /dev/null
ln -sf "$(pwd)/files/base16-shell" "${HOME}/.config/"
echo -e "Creating symlink for dotfiles\n"

# symlink all the dotfiles (excluding .bashrc.d which is handled per-file below)
mapfile -d '' -t files < <(find "$(pwd)/files" -maxdepth 1 -name ".*" -not -name ".gitignore" -not -name ".swp" -not -name ".bashrc.d" -print0)
for f in "${files[@]}"; do
	ln -sf "$f" "$HOME"
done

# Symlink individual .bashrc.d files so multiple aspects can contribute their own.
# Remove old directory symlink if present and replace with a real directory.
if [[ -L "${HOME}/.bashrc.d" ]]; then
	rm "${HOME}/.bashrc.d"
fi
mkdir -p "${HOME}/.bashrc.d"
for f in "$(pwd)/files/.bashrc.d/"*.bash; do
	ln -sf "$f" "${HOME}/.bashrc.d/"
done

echo -e "Symlinks Created \n"
popd &> /dev/null
 
